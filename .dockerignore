.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Build artifacts
frontend/dist/
*.log

# OS files
.DS_Store
Thumbs.db

# Misc
*.md
frontend/Researchers_c7.jsx
frontend/Researchers_db.jsx
frontend/StudentsResearchLab/
